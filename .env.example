IMAGE_TAG=latest
APP_ENV=production
TZ=Asia/Yekaterinburg
HTTP_PORT=8080

VITE_API_BASE_URL=https://taxi.dev.wkfc.ru/api/v1
VITE_WS_URL=wss://taxi.dev.wkfc.ru/api/v1/ws
VITE_USE_MOCK_API=false

POSTGRES_DB=taxi
POSTGRES_USER=taxi
POSTGRES_PASSWORD=change_me_strong_postgres_password

REDIS_PASSWORD=change_me_strong_redis_password

JWT_SECRET=change_me_access_secret_32_bytes_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_32_bytes_minimum

CORS_ALLOWED_ORIGINS=https://taxi.dev.wkfc.ru
LOGGER_LEVEL=info
RATE_LIMIT_PER_MINUTE=120

DISPATCH_INITIAL_RADIUS_METERS=10000
DISPATCH_MAX_RADIUS_METERS=100000
DISPATCH_RADIUS_STEP_METERS=1000
DISPATCH_MAX_DRIVERS_PER_OFFER=5
DISPATCH_DRIVER_LOCATION_MAX_AGE=90s
DISPATCH_OFFER_TTL=45s
DISPATCH_ACCEPT_LOCK_TTL=90s
DISPATCH_WORKER_POLL_TIMEOUT=10s
DISPATCH_RECOVERY_INTERVAL=30s